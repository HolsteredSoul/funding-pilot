# ═══════════════════════════════════════════════════════════════════
# AU-Funding-Arb v1.0 — Environment Configuration
# Copy to .env and fill in your values.
# All variables are prefixed with ARB_.
# ═══════════════════════════════════════════════════════════════════

# ── Exchange ────────────────────────────────────────────────────────
ARB_EXCHANGE=bybit              # "bybit" or "okx"
ARB_API_KEY=your_api_key_here
ARB_API_SECRET=your_api_secret_here
ARB_API_PASSPHRASE=             # OKX only

# ── Modes ───────────────────────────────────────────────────────────
ARB_DRY_RUN=true                # true = read-only (no orders placed)
ARB_TESTNET=false               # true = use exchange sandbox/testnet
ARB_CROSS_EXCHANGE_MODE=false   # advanced — keep disabled

# ── Strategy — Entry ───────────────────────────────────────────────
ARB_MIN_CURRENT_FUNDING=0.0002  # 0.02% minimum current funding rate
ARB_MIN_PROFITABLE_CYCLES=3    # trailing avg window (periods)
ARB_EXPECTED_HOLDING_PERIODS=8 # expected settlement periods to hold
ARB_MAX_CONCURRENT_PAIRS=5     # max simultaneous hedges
ARB_POSITION_SIZE_USD=1000     # USD per pair
ARB_MIN_POSITION_USD=500
ARB_MAX_POSITION_USD=2000
ARB_MAX_PORTFOLIO_PCT=0.02     # max 2% of portfolio per pair

# ── Strategy — Exit ────────────────────────────────────────────────
ARB_FUNDING_FLOOR=0.0001       # 0.01% — close below this
ARB_BASIS_DIVERGENCE_SIGMA=3.0 # basis > 3σ triggers exit
ARB_HARD_STOP_LOSS_PCT=-0.02   # -2% hard stop per pair
ARB_FUNDING_NEGATIVE_HOURS=24  # close after 24h negative funding

# ── Fees (Bybit VIP-0 defaults — adjust for your tier) ────────────
ARB_SPOT_MAKER_FEE=0.001
ARB_SPOT_TAKER_FEE=0.001
ARB_PERP_MAKER_FEE=0.0002
ARB_PERP_TAKER_FEE=0.00055

# ── Execution ──────────────────────────────────────────────────────
ARB_URGENCY_TIMEOUT_S=30       # seconds before limit→market fallback
ARB_ORDER_POLL_INTERVAL_S=2.0

# ── Safety ─────────────────────────────────────────────────────────
ARB_CIRCUIT_BREAKER_PCT=0.05   # 5% drawdown halts trading

# ── Loop Intervals ─────────────────────────────────────────────────
ARB_SCAN_INTERVAL_MIN=60
ARB_HEALTH_INTERVAL_S=30
ARB_SETTLEMENT_INTERVAL_H=8

# ── File Paths ─────────────────────────────────────────────────────
ARB_DATA_DIR=data
ARB_POSITIONS_FILE=positions.json
ARB_TRADES_CSV=trades_aud.csv
ARB_RBA_CACHE_FILE=rba_rates.csv

# ── Telegram ───────────────────────────────────────────────────────
ARB_TELEGRAM_TOKEN=             # BotFather token
ARB_TELEGRAM_CHAT_ID=           # your chat/group ID
ARB_DAILY_RECAP_HOUR_AWST=7    # 7am AWST daily summary

# ── Locale ─────────────────────────────────────────────────────────
ARB_TIMEZONE=Australia/Perth    # AWST (UTC+8)
